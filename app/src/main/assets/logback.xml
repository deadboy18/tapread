<configuration>
    <appender name="LOGCAT" class="ch.qos.logback.classic.android.LogcatAppender">
        <tagEncoder>
            <pattern>%logger{12}</pattern>
        </tagEncoder>
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <root level="DEBUG">
        <appender-ref ref="LOGCAT" />
    </root>

    <!-- EMV library: INFO to reduce noise -->
    <logger name="com.github.devnied" level="INFO" />
    <logger name="fr.devnied" level="INFO" />
</configuration>
